# Public Next.js deployment: required bearer token for all /api/* routes.
SUPER_COACH_API_TOKEN=

# Convex environment variable: required by POST /health.
# Configure the webhook sender to use X-Webhook-Secret or ?secret=.
HEALTH_WEBHOOK_SECRET=

# Created by `npx convex dev`; safe deployment URL, not a credential.
NEXT_PUBLIC_CONVEX_URL=
