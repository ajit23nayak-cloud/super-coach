# Explicit local-only development bypass. Never enable in production.
SUPER_COACH_DEV_LOOPBACK_BYPASS=0

# Public Next.js deployment: required bearer token for all /api/* routes.
SUPER_COACH_API_TOKEN=

# Shared only between Next.js server routes and authenticated Convex HTTP actions.
SUPER_COACH_DATA_SECRET=

# Convex environment variable: required by POST /health.
# Configure the webhook sender to use X-Webhook-Secret or ?secret=.
HEALTH_WEBHOOK_SECRET=

# Created by `npx convex dev`; safe deployment URLs, not credentials.
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
